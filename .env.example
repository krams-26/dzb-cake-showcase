# ── Frontend (Vite) ──────────────────────────────────────────────────────────
# URL de l’API (vide = chemins relatifs /api, avec proxy Vite vers le serveur Node)
# En production derrière un reverse proxy, laisser vide si /api est sur le même domaine.
# Sinon : VITE_API_BASE_URL=https://api.votredomaine.com
# VITE_API_BASE_URL=
#
# ── Vercel (hébergement uniquement sur vercel.app) ────────────────────────────
# Avec le dépôt actuel, les routes /api/* sont des Serverless Functions (dossier /api).
# Aucune variable n’est obligatoire : le front appelle /api en relatif sur le même domaine.
# Si vous hébergez l’API Express + MySQL ailleurs plus tard, définissez alors :
# VITE_API_BASE_URL=https://votre-api.example.com

# Copier vers .env ou .env.local (npm run server charge .env puis .env.local avec priorité au local)
#
# ── API Node (npm run server) — base MySQL dzb_cake ───────────────────────────
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=
DATABASE_NAME=dzb_cake

# Port de l’API REST (doit être identique au proxy Vite : lu depuis .env via loadEnv)
API_PORT=8787
#
# En local : lancer l’API ET le front (sinon « Cannot POST /api/auth/login ») :
#   npm run dev:full
# ou deux terminaux : npm run server   puis   npm run dev

# Session personnel (obligatoire en production : NODE_ENV=production)
SESSION_SECRET=changez-moi-en-production-min-32-caracteres
# SESSION_COOKIE_NAME=dzb.sid

# Origine exacte du front (CORS + cookies) — ex. https://www.votredomaine.com
# FRONTEND_ORIGIN=http://localhost:3000

# Créer un compte staff : npm run db:migrate puis
# STAFF_EMAIL=admin@example.com STAFF_PASSWORD=votreMotDePasse npm run db:create-staff

# Base MySQL : npm run db:migrate puis npm run db:seed (ou npm run db:setup)
# Fichiers : database/migrations/*.sql + database/seed_demo.sql

# Tests E2E (optionnel) : connexion tableau de bord
# E2E_STAFF_EMAIL=
# E2E_STAFF_PASSWORD=
