{
  "name": "vite-react-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "node server/index.js",
    "start": "node server/index.js",
    "db:migrate": "node scripts/migrate.js",
    "db:seed": "node scripts/seed.js",
    "db:setup": "node scripts/migrate.js && node scripts/seed.js",
    "db:create-staff": "node scripts/create-staff.js",
    "db:seed-staff-demo": "node scripts/seed-staff-demo.js",
    "dev:full": "concurrently -k -n api,web -c blue,green \"npm run server\" \"npm run dev\"",
    "build": "vite build",
    "preview": "vite preview",
    "lint:css": "stylelint \"src/**/*.css\" --fix --quiet",
    "lint:js": "eslint . --ext ts,tsx --report-unused-disable-directives",
    "lint:types": "tsc --noEmit",
    "check:css-vars": "node scripts/check-css-variables.js",
    "check:css-classes": "node scripts/check-css-classes.js",
    "lint": "npm run lint:types && npm run lint:js && npm run lint:css && npm run check:css-vars && npm run check:css-classes",
    "lint:ci": "node --max-old-space-size=8192 ./node_modules/eslint/bin/eslint.js . --ext ts,tsx --report-unused-disable-directives && npm run lint:types && npm run lint:css && npm run check:css-vars && npm run check:css-classes",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "@playwright/test": "^1.57.0",
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.1",
    "vite": "^7.2.4"
  },
  "dependencies": {
    "@blinkdotnew/ui": "0.4.0",
    "@dnd-kit/core": "^6.3.1",
    "@hookform/resolvers": "^5.2.2",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-router": "^1.168.4",
    "@vitejs/plugin-react": "5.2.0",
    "autoprefixer": "10.4.16",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express-session": "^1.18.1",
    "bcryptjs": "^3.0.2",
    "express": "^4.21.2",
    "mysql2": "^3.12.0",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "glob": "^13.0.6",
    "lucide-react": "0.471.0",
    "postcss": "8.4.31",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.72.0",
    "react-hot-toast": "^2.6.0",
    "react-resizable-panels": "2.1.7",
    "react-responsive": "^10.0.1",
    "recharts": "^3.8.1",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "3.3.5",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6"
  },
  "overrides": {
    "react-resizable-panels": "2.1.7",
    "@blinkdotnew/ui": {
      "react-resizable-panels": "2.1.7"
    }
  }
}
